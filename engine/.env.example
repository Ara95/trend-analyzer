# Supabase (service-role key — SERVER-SIDE ONLY, never expose to the browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Apify
APIFY_TOKEN=your-apify-token

# Actor ids (swappable)
# TikTok is Class B (raw-content). clockworks/tiktok-scraper supports proxyCountryCode (real geo:
# TikTok's Swedish feed), returns textLanguage (geo gate) + videoMeta.coverUrl (thumbnails), and is
# ~$4/1000 results. Verified vs apidojo ($0.30/1000 but NO geo/language field) and free-tiktok-scraper
# ($5/1000, no real geo). See `npm run probe:flagship` / `probe:apidojo`.
TIKTOK_ACTOR_ID=clockworks/tiktok-scraper
# Videos scraped per TikTok profile per run (caps pay-per-result cost).
TIKTOK_RESULTS_PER_PAGE=10
INSTAGRAM_ACTOR_ID=apify/instagram-reel-scraper
# Content-first Instagram search actor (npm run collect:instagram). IG has NO geo proxy or language
# field (unlike TikTok), so this does keyword CAPTION search and we detect Swedish ourselves. See
# `npm run probe:ig-search` and memory apify-instagram-analysis. Verified vs the flagship
# apify/instagram-scraper (location search = sparse/tourism-skewed; shares behind paid tier).
IG_SEARCH_ACTOR_ID=patient_discovery/instagram-search-reels

# Classification (OPTIONAL). Without OPENAI_API_KEY only the deterministic panel + cache
# layers run; account inference (layer 3) and content escalation (layer 4) are skipped.
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TAG_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Classification thresholds (all optional; defaults shown).
CLASSIFY_CONFIDENCE_THRESHOLD=0.7
# Escalation velocity gate — RAW weighted-engagement-per-day units (likes*1 + comments*2 +
# shares*3 + views*0.05, per day), SIGNED. NOT a 0..1 value. Start high; tune down on real data.
CLASSIFY_VELOCITY_THRESHOLD=1000
CLASSIFY_CACHE_MAX_AGE_DAYS=30
CLASSIFY_ACCOUNT_RECENT_POSTS=12
CLASSIFY_ESCALATION_LIMIT=50
CLASSIFY_ESCALATION_WINDOW_DAYS=7
CLASSIFY_SIMILARITY_FLOOR=0.15

# Content-first collection (npm run collect / rescore). All optional; defaults shown.
# Swedish free-text searches (match caption text → surface un-hashtagged trends). One query per
# industry for cross-category coverage; geo is proxyCountryCode=SE so plain Swedish words are fine.
SE_SEARCH_QUERIES=recept,träning,sminkning,mode,sverige,humor,fotboll,gaming,resor,inredning,teknik,familj,husdjur,nyheter,ekonomi,bil,musik
# Videos scraped per search query in `collect` (volume = cost). The actor caps reliable depth at one
# page (~12-14 videos); 14 is the top of that range. Breadth (more queries) is the volume lever.
COLLECT_RESULTS_PER_PAGE=14
# Freshness ceiling (days) for the video index: videos older than this are not ingested and are pruned
# by the search worker. Must match the web read-cap (web/lib/videos.ts MAX_AGE_DAYS). 30 = "no trends
# older than a month". On-demand scrapes also ask TikTok for PAST_MONTH so this rarely has to drop rows.
INDEX_MAX_AGE_DAYS=30
# On-demand search scrapes three age tiers per term (PAST_24_HOURS / PAST_WEEK / PAST_MONTH), this many
# EACH → up to 3x this many distinct videos after dedup (15 → ~45). Three charged date-filtered runs per
# search, so this is the main per-search Apify cost lever.
SEARCH_RESULTS_PER_BUCKET=15
# Also run a hashtag pass in `collect`? Off by default (search already catches un-hashtagged content;
# hashtags mostly re-scrape the same videos at ~2x cost). Set true to add it.
COLLECT_INCLUDE_HASHTAGS=false
# Top-ranked trends classified + persisted per period. No Apify cost (only classification). 150 so
# the Month window isn't capped — more of the ranked scrape becomes trends.
CONTENT_TREND_LIMIT=150
# Discovery (npm run discover) — its own hashtag seeds + volume, independent of collect above.
SE_DISCOVERY_HASHTAGS=svensktiktok,sverige,svenskmat,träningsverige,svenskskönhet
SE_DISCOVERY_RESULTS_PER_HASHTAG=30
# Soft geo gate: keep only these textLanguage values ('un' = undetermined, kept).
SE_ALLOWED_LANGUAGES=sv,un
# Content-first Instagram (npm run collect:instagram). Queries MUST be Swedish-distinct (åäö / no
# foreign cognate) since the IG search actor ranks globally with no geo — the caption language gate
# discards the rest. Probe yields: träning 92%, inredning 83%, recept 8% (false friend — excluded).
# Volume from breadth (more queries, one per industry), not pages.
IG_SEARCH_QUERIES=träning,inredning,sminkning,hälsa,bakning,vardag,trädgård,resa,kläder,fotboll,föräldraledig,husdjur,skönhet,matlagning
# Pages per query. The actor ranks by popularity not recency, so page 1 is mostly weeks-old reels.
# Raising this (roughly linear cost) adds usable reels + a thin fresh tail so Day/Week windows aren't
# empty. Diminishing returns + more >30d waste beyond ~3-4. See `npm run probe:ig-fresh`.
IG_MAX_PAGES=4

# Trend cutoff: a video is is_breakout when its robust z within its period cohort crosses this.
# 3.5 = classic outlier cutoff; lower to surface more trends, raise to be stricter.
TREND_BREAKOUT_Z=3.5
# Min views for the virality axis to count toward a breakout — below this, engagement ratios are a
# small-denominator artifact, not a real trend. `npm run rescore` prints the views distribution.
TREND_MIN_VIRALITY_VIEWS=10000
